# Netlify: https://docs.netlify.com/routing/headers/

# Hashed JS/CSS/fonts from Vite — safe to cache “forever”
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Optional: long cache for favicon (swap file by bumping name if you change it often)
/favicon.svg
  Cache-Control: public, max-age=604800
